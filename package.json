{
  "name": "career-ops-plugin-gatekeeper",
  "version": "0.1.0",
  "description": "Hardball: a JD-specific, one-shot adversarial resume screen that role-plays the skeptical hiring manager to try to screen you out, then returns only truthful fixes.",
  "license": "MIT",
  "author": "Dax Davis <dax@rubicontv.com>",
  "homepage": "https://github.com/rubicon/career-ops-plugin-gatekeeper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubicon/career-ops-plugin-gatekeeper.git"
  },
  "bugs": {
    "url": "https://github.com/rubicon/career-ops-plugin-gatekeeper/issues"
  },
  "keywords": [
    "career-ops",
    "career-ops-plugin",
    "resume",
    "cv",
    "job-description",
    "screening",
    "ats"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node test/gatekeeper.mjs && node test/skill.mjs && node test/smoke.mjs",
